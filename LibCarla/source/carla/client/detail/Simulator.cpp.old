  rpc::MapInfo Simulator::GetMapInfo() {
    return _client.GetMapInfo(_episode->GetToken());
  }

  std::shared_ptr<Map> Simulator::GetCurrentMap() {
    const auto info = GetMapInfo();
    if (_cached_map == nullptr || (_cached_map->GetName() != info.name)) {
      log_info("loading new map '", info.name, "' with ", info.size, " bytes");
      auto str = GetMapData();
      _cached_map = std::make_shared<Map>(info, std::move(str));
    }
    return _cached_map;
  }

  SharedPtr<Actor> Simulator::GetSpectator() {
    return ActorFactory::MakeActor(GetWorld(), _client.GetSpectator(_episode->GetToken()), _gc_policy);
  }

