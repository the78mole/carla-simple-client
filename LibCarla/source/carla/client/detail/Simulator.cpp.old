  WorldSnapshot Simulator::WaitForTick(time_duration timeout) {
    return WorldSnapshot{_client.WaitForTick(_episode->GetToken(), timeout)};
  }

  size_t Simulator::RegisterOnTickEvent(std::function<void(WorldSnapshot)> callback) {
    return _client.SubscribeToStream(
        _episode->GetToken(),
        carla::streaming::Stream::token_type(streaming::detail::token_data(GetEpisodeInfo().id, 0u)),
        [callback](auto buffer) {
          callback(WorldSnapshot::Load(std::move(buffer)));
        });
  }

  void Simulator::RemoveOnTickEvent(size_t id) {
    _client.UnSubscribeFromStream(_episode->GetToken(), id);
  }

  void Simulator::Tick(time_duration timeout) {
    _client.SendTickCue(_episode->GetToken());
    _client.WaitForTick(_episode->GetToken(), timeout);
  }

  void Simulator::SetSynchronousMode(bool synchronous) {
    rpc::EpisodeSettings settings;
    settings.synchronous_mode = synchronous;
    SetEpisodeSettings(settings);
  }

  bool Simulator::GetSynchronousMode() {
    return GetEpisodeSettings().synchronous_mode;
  }

  void Simulator::SetFixedDeltaSeconds(double delta_seconds) {
    rpc::EpisodeSettings settings = GetEpisodeSettings();
    settings.fixed_delta_seconds = delta_seconds;
