  // Implementation mostly copied from original but with all navigation 
  // functionality stubbed out for ARM64 compatibility

  Simulator::Simulator(
      const std::string &host,
      uint16_t port,
      size_t worker_threads,
      bool enable_garbage_collection)
    : _client(host, port, worker_threads),
      _light_manager(MakeEpisodeProxy(host, port, worker_threads)),
      LIBCARLA_INITIALIZE_LIFETIME_PROFILER(),
      _gc_policy(enable_garbage_collection ?
          GarbageCollectionPolicy::Enabled :
          GarbageCollectionPolicy::Disabled) {}

  Simulator::~Simulator() = default;

  EpisodeProxy Simulator::MakeEpisodeProxy(
      const std::string &host,
      uint16_t port,
      size_t worker_threads) {
    return _client.Subscribe(host, port, worker_threads);
  }

  std::string Simulator::GetClientVersion() {
    return _client.version();
  }

  std::string Simulator::GetServerVersion() {
    return _client.GetServerVersion(_episode->GetToken());
  }

