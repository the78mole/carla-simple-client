  void Simulator::LoadWorld(std::string map_name) {
    _cached_map.reset();
    _episode = _client.LoadEpisode(_episode->GetToken(), std::move(map_name));
    _light_manager.SetEpisode(WeakEpisodeProxy{_episode});
  }

  SharedPtr<BlueprintLibrary> Simulator::GetBlueprintLibrary() {
    return std::make_shared<BlueprintLibrary>(_client.GetActorDefinitions(_episode->GetToken()));
  }

  SharedPtr<Actor> Simulator::SpawnActor(
      const ActorBlueprint &blueprint,
      const geom::Transform &transform,
      Actor *parent,
      rpc::AttachmentType attachment_type) {
    rpc::Actor actor = (parent != nullptr ?
        _client.SpawnActorWithParent(_episode->GetToken(), blueprint.MakeActorDescription(), transform, parent->GetId(), attachment_type) :
        _client.SpawnActor(_episode->GetToken(), blueprint.MakeActorDescription(), transform));
    DEBUG_ASSERT(actor.id != 0u);
    return ActorFactory::MakeActor(GetWorld(), std::move(actor), _gc_policy);
  }

  bool Simulator::DestroyActor(Actor &actor) {
    bool result = false;
    result = _client.DestroyActor(_episode->GetToken(), actor.GetId());
    if (result) {
      _episode->GetState().RemoveActor(actor.GetId());
    }
    return result;
  }

  SharedPtr<Actor> Simulator::GetActorById(ActorId id) {
    auto description = GetActorsById({id});
    return description.empty() ? nullptr : description[0u];
  }

  std::vector<SharedPtr<Actor>> Simulator::GetActorsById(const std::vector<ActorId> &actor_ids) {
    std::vector<SharedPtr<Actor>> result;
    result.reserve(actor_ids.size());
    auto actor_list = _client.GetActorsById(_episode->GetToken(), actor_ids);
    for (auto &&description : actor_list) {
      result.emplace_back(ActorFactory::MakeActor(GetWorld(), std::move(description), _gc_policy));
    }
    return result;
  }

  std::vector<SharedPtr<Actor>> Simulator::GetAllTheActorsInTheEpisode() {
    std::vector<SharedPtr<Actor>> result;
    auto actor_list = _client.GetAllTheActorsInTheEpisode(_episode->GetToken());
    for (auto &&description : actor_list) {
      result.emplace_back(ActorFactory::MakeActor(GetWorld(), std::move(description), _gc_policy));
    }
    return result;
  }

